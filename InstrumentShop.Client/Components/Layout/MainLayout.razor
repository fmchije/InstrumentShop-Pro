@inherits LayoutComponentBase

<style>
    .main-container {
        display: flex;
        min-height: 100vh;
        width: 100%;
    }

    .sidebar-area {
        width: 280px;
        background-color: #212529;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        height: 100vh;
    }

    .content-area {
        flex-grow: 1;
        padding: 30px;
        background-color: #f4f7f6;
    }
</style>

<div class="main-container">
    <div class="sidebar-area">
        <NavMenu />
    </div>

    <main class="content-area">
        @Body
    </main>
</div>